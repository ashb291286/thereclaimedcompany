// Reclaimed Marketplace - Prisma schema
// NextAuth v5 + Stripe Connect + Listings, Orders

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---- Enums ----
enum UserRole {
  individual
  reclamation_yard
}

enum ListingStatus {
  draft
  active
  sold
  ended // auction closed without sale (no bids or reserve not met)
  payment_pending // auction won; automatic charge failed or pending — winner must pay
}

enum OrderStatus {
  pending
  paid
  refunded
  disputed
}

enum Condition {
  like_new
  used
  worn
  parts_not_working
  refurbished
  upcycled
  collectable
}

enum ListingKind {
  sell
  auction
}

/// LOT = one price for the whole line; PER_UNIT = price × quantity (e.g. bricks).
enum ListingPricingMode {
  LOT
  PER_UNIT
}

enum OfferStatus {
  pending
  accepted
  declined
  withdrawn
  /// Buyer’s offer replaced by a seller counter (still in history).
  superseded
}

enum ListingLocalYardAlertStatus {
  PENDING
  DECLINED
}

enum WantedAdStatus {
  active
  fulfilled
  closed
}

/// Demolition / refurb salvage: one site project with multiple claimable lots.
enum DemolitionProjectStatus {
  draft
  active
  closed
}

enum DemolitionElementStatus {
  available
  reserved
  withdrawn
}

// ---- NextAuth (Auth.js v5) ----
model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  emailVerified DateTime?
  name          String?
  image         String?
  password      String?   // for credentials provider
  role          UserRole? // set when they become a seller
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  sellerProfile SellerProfile?
  ordersAsBuyer Order[]     @relation("Buyer")
  ordersAsSeller Order[]    @relation("Seller")
  listings      Listing[]
  offersMade    Offer[]     @relation("OffersMade")
  bids          Bid[]
  wantedAds     WantedAd[]
  notifications Notification[]
  listingFavorites ListingFavorite[]

  /// Set at credentials sign-up: "buying" | "selling" (drives buyer welcome flow).
  registrationIntent   String?
  /// Buyer’s saved area for distance hints on listings (UK postcode + geocode).
  homePostcode         String?
  homeLat              Float?
  homeLng              Float?
  homeAdminDistrict    String?
  homeRegion           String?
  /// Town / built-up area label from postcodes.io (bua or ttwa) for friendlier UI than council name.
  homePostcodeLocality String?
  buyerWelcomeCompletedAt DateTime?

  stripeCustomerId     String? @unique // platform Customer for saved auction payment method
  bidPaymentMethodId   String? // default PaymentMethod id (card on file for bids)
  localYardAlerts          ListingLocalYardAlert[] @relation("YardLocalAlerts")
  propRentalBookingsAsHirer PropRentalBooking[] @relation("PropRentalHirer")
  propRentalSets            PropRentalSet[]
  propListingDrafts         PropListingDraft[]
  seenOnScreenRequested     SeenOnScreenVerificationRequest[] @relation("SeenOnScreenRequestedBy")
  seenOnScreenReviewed      SeenOnScreenVerificationRequest[] @relation("SeenOnScreenReviewedBy")
  demolitionProjectsOrganized DemolitionProject[]
  demolitionElementsClaimed   DemolitionElement[]              @relation("DemolitionElementClaimedBy")
  demolitionElementInterests  DemolitionElementInterest[]

  yardEnquiriesReceived YardEnquiry[]   @relation("YardEnquiriesReceived")
  yardEnquiriesSent     YardEnquiry[]   @relation("YardEnquiriesSent")
  yardStockAlerts       YardStockAlert[] @relation("YardStockAlertsByUser")
  yardStockAlertFans    YardStockAlert[] @relation("YardStockAlertsForSeller")
  drivenAuctionComments DrivenAuctionComment[]
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}

// ---- Seller profile (1:1 when user sells) ----
model SellerProfile {
  id                String    @id @default(cuid())
  userId            String    @unique
  businessName      String?   // for reclamation_yard
  displayName       String
  postcode          String
  lat               Float?
  lng               Float?
  adminDistrict     String?   // council / borough (postcodes.io admin_district)
  region            String?   // e.g. England region / London
  postcodeLocality  String?   // town / BUA / TTWA from postcodes.io — shown to users
  openingHours         String?  // legacy free text (optional fallback)
  openingHoursSchedule Json?    // structured Mon–Sun for reclamation yards
  yardSlug             String?  @unique // public SEO URL for reclamation yards only
  yardTagline          String?   // short line for SEO / hero
  yardAbout            String?   @db.Text // longer about copy for page + meta
  yardLogoUrl          String?
  yardHeaderImageUrl   String?
  yardContactEmail     String?
  yardContactPhone     String?
  yardWebsiteUrl       String?
  yardSocialJson       Json?    // instagram, facebook, x, linkedin, tiktok URLs
  verificationStatus String?  @default("none") // none | pending | verified
  /// UK VAT-registered reclamation yards: listing prices stored ex VAT; buyers pay +20% at checkout.
  vatRegistered     Boolean   @default(false)
  stripeAccountId   String?   // Stripe Connect account id when onboarding complete
  /// Up to three buyer-facing material labels (e.g. timber, brick) for SEO H2 and pills.
  yardPrimaryMaterials      String[] @default([])
  /// Enabled trust badges, e.g. { "familyRun": true, "delivery": true } — UI merges with defaults.
  yardTrustFlagsJson        Json?
  /// Extra single “why us” line shown in trust row + why-buy section.
  yardCustomTrustLine       String?
  /// Delivery / collection JSON: collect, deliver, radiusMiles, minOrderGbp, notes.
  yardDeliveryOptionsJson   Json?
  /// Free-text regions / counties served (map + copy).
  yardServiceAreas          String?  @db.Text
  /// E.164 or UK local digits for wa.me link.
  yardWhatsApp              String?
  yearEstablished           Int?
  /// trade | public | both
  yardTradePublic           String?
  /// Shown near enquiry form, e.g. “Typically responds within 24 hours”.
  yardResponseTimeNote      String?

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// Buyer / guest message to a reclamation yard (public profile).
model YardEnquiry {
  id         String    @id @default(cuid())
  yardUserId String
  fromUserId String?
  name       String
  email      String
  phone      String?
  message    String    @db.Text
  quantity   String?
  imageUrl   String?
  readAt     DateTime?
  createdAt  DateTime  @default(now())

  yardUser User  @relation("YardEnquiriesReceived", fields: [yardUserId], references: [id], onDelete: Cascade)
  fromUser User? @relation("YardEnquiriesSent", fields: [fromUserId], references: [id], onDelete: SetNull)

  @@index([yardUserId, createdAt])
}

/// Logged-in user wants notifications when a yard lists new stock (optionally per category).
model YardStockAlert {
  id         String   @id @default(cuid())
  userId     String
  sellerId   String
  categoryId String?
  createdAt  DateTime @default(now())

  user     User      @relation("YardStockAlertsByUser", fields: [userId], references: [id], onDelete: Cascade)
  seller   User      @relation("YardStockAlertsForSeller", fields: [sellerId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([sellerId])
  @@index([userId, createdAt])
}

// ---- Embodied carbon (ICE-style factors; admin-editable) ----
model CarbonFactor {
  id               String   @id @default(cuid())
  materialType     String // slug: timber, brick, steel, concrete, tile, other
  unitType         String // kg | m3 | tonne (factor is CO2e per this unit)
  co2PerUnit       Float // kg CO2e per unit
  source           String   @default("ICE Database")
  label            String // display name, e.g. "Timber (general)"
  densityKgPerM3   Float? // when converting m³ → kg for waste mass if unit is m3 row
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([materialType, unitType])
  @@index([materialType])
}

// ---- Categories ----
model Category {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  parentId  String?
  parent    Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryHierarchy")
  listings  Listing[]
  wantedAds WantedAd[]
  yardStockAlerts YardStockAlert[]
  /// When true, new/updated active marketplace listings in this category sync to WooCommerce as external (affiliate) products.
  wooCommerceSyncEnabled  Boolean @default(false)
  /// WooCommerce product category term ID (integer) assigned to synced products.
  wooCommerceCategoryId   Int?
}

// ---- Listings ----
model Listing {
  id                String        @id @default(cuid())
  sellerId          String
  title             String
  /// Optional stock / yard reference (e.g. SKU) — shown on the listing for buyers.
  sellerReference   String?
  description       String
  price             Int // asking (sell) or starting bid (auction), pence; 0 when freeToCollector
  condition         Condition
  categoryId        String
  postcode          String?
  lat               Float?
  lng               Float?
  adminDistrict     String?
  region            String?
  postcodeLocality  String?  // town / BUA label for browse cards (postcodes.io)
  images            String[] // blob URLs
  status            ListingStatus @default(draft)
  listingKind       ListingKind   @default(sell)
  pricingMode       ListingPricingMode @default(LOT)
  unitsAvailable    Int? // when PER_UNIT: units in stock; decremented on purchase until sold
  freeToCollector   Boolean       @default(false) // sell only: free pickup, no payment
  offersDelivery    Boolean       @default(false) // seller may arrange delivery (as well as collection)
  deliveryNotes     String? // extra context: packing, cut-offs, areas
  deliveryCostPence Int? // lowest fixed option in pence; null if all quote-only (legacy + summary)
  deliveryOptions   Json? // [{ carrier, customLabel?, pricePence | null }] preset carriers + prices
  auctionEndsAt        DateTime? // auction only: bidding closes at this time (UTC)
  auctionReservePence  Int? // optional minimum winning amount (pence); null = no reserve
  auctionFinalizedAt   DateTime? // set after end-of-auction settlement (reserve check / charge)
  boostedUntil         DateTime? // paid promotion window end timestamp
  boostLastPaymentIntentId String? // last processed Stripe PI for idempotency
  notifyLocalYards     Boolean   @default(false) // ping reclamation yards within radius when published (fixed-price sell)
  /// When false, listing is omitted from marketplace browse/search; yards may use for Prop Yard hire only.
  visibleOnMarketplace Boolean   @default(true)
  /// When true, marketplace visibility was turned off automatically because the item was OUT_ON_HIRE; restore when no longer on hire.
  marketplaceVisibleBeforePropHirePause Boolean?
  // Material / carbon (optional; ICE-based estimates when provided)
  materialType           String? // matches CarbonFactor.materialType
  materialQuantity       Float?
  materialUnit           String? // kg | tonne | m3
  distanceSavedKm        Float? // optional user note; not used in core formula yet
  carbonSavedKg          Float? // cached embodied carbon avoided (kg CO2e)
  carbonWasteDivertedKg  Float? // mass diverted (kg)
  carbonImpactJson       Json? // full breakdown for UI / API
  descriptionShort       String?
  descriptionFull        String? @db.Text
  propSubcategory        String?
  quantityAvailable      Int?
  dimensionsH            Float?
  dimensionsW            Float?
  dimensionsD            Float?
  weightKg               Float?
  propMaterials          String[]  @default([])
  propColours            String[]  @default([])
  colourHex              String?
  colourName             String?
  conditionGrade         PropConditionGrade?
  eraTags                String[]  @default([])
  dateSpecific           String?
  styleTags              String[]  @default([])
  geographicOrigin       String?
  genreTags              String[]  @default([])
  settingInteriorTags    String[]  @default([])
  settingExteriorTags    String[]  @default([])
  flagSuitableCloseup    Boolean   @default(false)
  flagCameraReady        Boolean   @default(false)
  flagPreviouslyUsedOnProduction Boolean @default(false)
  flagFragile            Boolean   @default(false)
  flagOutdoorSuitable    Boolean   @default(false)
  flagMultiplesAvailable Boolean   @default(false)
  flagCanSourceMatching  Boolean   @default(false)
  flagStudioDelivery     Boolean   @default(false)
  productionName         String?
  studioTags             String[]  @default([])
  studioOtherText        String?
  provenanceBuilding     String?
  provenanceDateText     String?
  provenanceRegion       String?
  provenanceDocs         String[]  @default([])
  provenanceDocsAvailable Boolean  @default(false)
  authenticityVerifiedBy PropAuthenticityVerifiedBy?
  restorationNotes       String?   @db.Text
  conditionNotes         String?   @db.Text
  hireEnabled            Boolean   @default(false)
  saleEnabled            Boolean   @default(true)
  hirePriceWeekPence     Int?
  hireMinPeriod          PropHireMinPeriod?
  hireDepositPct         Float?
  hireBlockedDates       Json?
  damageWaiverTerms      String?   @db.Text
  salePricePence         Int?
  saleOffers             Boolean   @default(false)
  collectionAddress      String?
  collectionAvailable    Boolean   @default(true)
  collectionOpeningHours String?
  deliveryAvailable      Boolean   @default(false)
  deliveryRadiusMiles    Int?
  deliveryNationwide     Boolean   @default(false)
  deliveryPriceType      PropDeliveryPriceType?
  deliveryPricePence     Int?
  specialistHandling     Boolean   @default(false)
  regularStudioRun       Boolean   @default(false)
  specialistTransportRequired Boolean @default(false)
  deliveryLeadTime       String?
  heroImageUrl           String?
  detailShots            Json?
  videoUrl               String?
  view360Url             String?
  seenOnScreenProductions String[] @default([])
  propListingStatus      PropListingStatus @default(DRAFT)
  publishedAt            DateTime?
  /// WooCommerce external product ID when synced (see Category.wooCommerceSyncEnabled).
  wooCommerceProductId   Int?      @unique
  wooCommerceSyncedAt    DateTime?
  wooCommerceLastError   String?   @db.Text
  createdAt            DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  seller   User     @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id])
  orders   Order[]
  offers   Offer[]
  bids     Bid[]
  favorites ListingFavorite[]
  viewEvents ListingViewEvent[]
  localYardAlerts ListingLocalYardAlert[]
  propRentalOffer PropRentalOffer?
  propListingDrafts PropListingDraft[]
  seenOnScreenRequests SeenOnScreenVerificationRequest[]

  @@index([sellerId])
  @@index([categoryId])
  @@index([status])
  @@index([lat, lng])
  @@index([createdAt])
  @@index([listingKind])
  @@index([hireEnabled, saleEnabled, propListingStatus])
  @@index([conditionGrade])
  @@index([authenticityVerifiedBy])
}

// ---- The Prop Yard (film / TV hire layer; reclamation yards only; links to existing listings) ----

enum PropRentalFulfillment {
  COLLECT_AND_RETURN
  YARD_DELIVERS_AND_COLLECTS
  ARRANGE_SEPARATELY
}

enum PropRentalBookingStatus {
  REQUESTED
  CONFIRMED
  OUT_ON_HIRE
  RETURNED
  CANCELLED
  DECLINED
}

/// Production / commission type for a Prop Yard hire set (hirer-facing metadata).
enum PropRentalSetProductionType {
  FEATURE_FILM
  TELEVISION_STREAMING
  COMMERCIAL
  MUSIC_VIDEO
  THEATRE_STAGE
  DOCUMENTARY_FACTUAL
  STILLS_EDITORIAL
  EVENT_EXHIBITION
  OTHER
}

enum PropConditionGrade {
  A
  B
  C
}

enum PropAuthenticityVerifiedBy {
  YARD_OWNER_KNOWLEDGE
  INDEPENDENT_EXPERT
  SALVO_MEMBER
  LAPADA_MEMBER
  UNVERIFIED
}

enum PropListingStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum PropHireMinPeriod {
  ONE_DAY
  THREE_DAYS
  ONE_WEEK
  TWO_WEEKS
  ONE_MONTH
}

enum PropDeliveryPriceType {
  FREE
  FIXED
  POA
  DISTANCE
}

/// One active prop-rental configuration per marketplace listing.
model PropRentalOffer {
  id               String   @id @default(cuid())
  listingId        String   @unique
  weeklyHirePence  Int // ex-VAT display; platform T&Cs apply
  minimumHireWeeks Int      @default(1)
  isActive         Boolean  @default(true)
  yardHireNotes    String?  @db.Text // collection, condition, deposit notes for hirers
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  listing         Listing                  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  bookings        PropRentalBooking[]
  unavailability  PropRentalUnavailability[]
  setItems PropRentalSetItem[]

  @@index([isActive])
  @@index([weeklyHirePence])
}

model PropListingDraft {
  id        String   @id @default(cuid())
  yardId    String
  listingId String?
  payload   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  yard    User     @relation(fields: [yardId], references: [id], onDelete: Cascade)
  listing Listing? @relation(fields: [listingId], references: [id], onDelete: SetNull)

  @@index([yardId, updatedAt])
  @@index([listingId])
}

model SeenOnScreenVerificationRequest {
  id             String   @id @default(cuid())
  listingId      String
  requestedById  String
  productionName String
  note           String?
  status         String   @default("PENDING")
  reviewedById   String?
  reviewedAt     DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  listing     Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  requestedBy User    @relation("SeenOnScreenRequestedBy", fields: [requestedById], references: [id], onDelete: Cascade)
  reviewedBy  User?   @relation("SeenOnScreenReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([listingId, status])
  @@index([requestedById, createdAt])
}

/// Production / art-department "set" — a hirer builds a list of props before sending hire requests.
model PropRentalSet {
  id               String                      @id @default(cuid())
  userId           String
  name             String                      @default("Untitled set")
  productionType   PropRentalSetProductionType?
  /// Optional production window: prefilled when adding props to this set (UTC calendar dates).
  defaultHireStart DateTime?
  defaultHireEnd   DateTime?
  createdAt        DateTime                    @default(now())
  updatedAt        DateTime                    @updatedAt

  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  items           PropRentalSetItem[]
  bookingsFromSet PropRentalBooking[]

  @@index([userId])
  @@index([productionType])
}

model PropRentalSetItem {
  id                       String              @id @default(cuid())
  setId                    String
  offerId                  String
  hireStart                DateTime
  hireEnd                  DateTime
  fulfillment              PropRentalFulfillment
  hirerOrgName             String?
  productionNotes          String?             @db.Text
  deliveryArrangementNotes String?             @db.Text
  createdAt                DateTime            @default(now())
  updatedAt                DateTime            @updatedAt

  set   PropRentalSet   @relation(fields: [setId], references: [id], onDelete: Cascade)
  offer PropRentalOffer @relation(fields: [offerId], references: [id], onDelete: Cascade)

  @@unique([setId, offerId])
  @@index([setId])
  @@index([offerId])
}

/// Yard-maintained blackout dates (maintenance, private hire, etc.).
model PropRentalUnavailability {
  id        String   @id @default(cuid())
  offerId   String
  startDate DateTime // inclusive, date-normalised UTC midnight
  endDate   DateTime // inclusive
  note      String?
  createdAt DateTime @default(now())

  offer PropRentalOffer @relation(fields: [offerId], references: [id], onDelete: Cascade)

  @@index([offerId])
  @@index([offerId, startDate])
}

model PropRentalBooking {
  id                       String                   @id @default(cuid())
  offerId                  String
  hirerId                  String
  hireStart                DateTime
  hireEnd                  DateTime
  billableWeeks            Int // ceil weeks between hireStart and hireEnd for quote
  totalHirePence           Int // pro-rata daily share of weekly rate, minimum minimumHireWeeks × weekly (snapshot)
  status                   PropRentalBookingStatus  @default(REQUESTED)
  fulfillment              PropRentalFulfillment
  contractAcceptedAt       DateTime?
  hirerOrgName             String?
  productionNotes          String?                  @db.Text
  deliveryArrangementNotes String?                  @db.Text
  hireRequestBatchId       String? // groups line items from one “send requests” submit
  propRentalSetId          String?
  stripeCheckoutSessionId  String?
  hirePaidAt               DateTime?
  createdAt                DateTime                 @default(now())
  updatedAt                DateTime                 @updatedAt

  offer           PropRentalOffer @relation(fields: [offerId], references: [id], onDelete: Cascade)
  hirer           User            @relation("PropRentalHirer", fields: [hirerId], references: [id], onDelete: Cascade)
  propRentalSet   PropRentalSet?  @relation(fields: [propRentalSetId], references: [id], onDelete: SetNull)

  @@index([offerId])
  @@index([hirerId])
  @@index([status])
  @@index([hireStart, hireEnd])
  @@index([hireRequestBatchId])
  @@index([propRentalSetId])
}

model ListingFavorite {
  id        String   @id @default(cuid())
  userId    String
  listingId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
  @@index([listingId])
}

model ListingViewEvent {
  id        String   @id @default(cuid())
  listingId String
  createdAt DateTime @default(now())

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId, createdAt])
}

// Fixed-price listings: seller opted in to notify reclamation yards within ~50 mi
model ListingLocalYardAlert {
  id             String                      @id @default(cuid())
  listingId      String
  yardUserId     String
  status         ListingLocalYardAlertStatus @default(PENDING)
  distanceMiles  Float?
  linkedOfferId  String?                     @unique
  createdAt      DateTime                    @default(now())
  respondedAt    DateTime?

  listing     Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  yardUser    User    @relation("YardLocalAlerts", fields: [yardUserId], references: [id], onDelete: Cascade)
  linkedOffer Offer?  @relation(fields: [linkedOfferId], references: [id], onDelete: SetNull)

  @@unique([listingId, yardUserId])
  @@index([yardUserId])
  @@index([listingId])
}

model Bid {
  id          String   @id @default(cuid())
  listingId   String
  bidderId    String
  amountPence Int
  createdAt   DateTime @default(now())

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  bidder  User    @relation(fields: [bidderId], references: [id], onDelete: Cascade)
  order   Order?

  @@index([listingId])
  @@index([bidderId])
  @@index([listingId, amountPence])
}

model Offer {
  id                 String      @id @default(cuid())
  listingId          String
  buyerId            String
  offeredPrice       Int // pence — agreed amount when accepted
  message            String?
  status             OfferStatus @default(pending)
  /// When true, the seller proposed this price; the buyer must accept/decline (still stored with buyerId).
  fromSellerCounter  Boolean     @default(false)
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  respondedAt        DateTime?

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  buyer   User    @relation("OffersMade", fields: [buyerId], references: [id], onDelete: Cascade)
  order   Order?
  localYardAlert ListingLocalYardAlert?

  @@index([listingId])
  @@index([buyerId])
  @@index([listingId, status])
}

model WantedAd {
  id             String         @id @default(cuid())
  userId         String
  title          String
  description    String
  categoryId     String?
  budgetMaxPence Int?
  postcode       String?
  lat            Float?
  lng            Float?
  adminDistrict     String?
  region            String?
  postcodeLocality  String?
  status         WantedAdStatus @default(active)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([categoryId])
}

model DemolitionProject {
  id                  String                  @id @default(cuid())
  organizerId         String
  title               String
  description         String                  @db.Text
  siteAddress         String?
  postcode            String
  lat                 Float?
  lng                 Float?
  adminDistrict       String?
  region              String?
  postcodeLocality    String?
  /// Site access: where to meet, gate times, induction, etc.
  accessWhereWhen     String?                 @db.Text
  /// Insurance, method statements, general strip-out rules.
  conditionsGeneral   String?                 @db.Text
  images              String[]                @default([])
  status              DemolitionProjectStatus @default(draft)
  publishedAt         DateTime?
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt

  organizer User                @relation(fields: [organizerId], references: [id], onDelete: Cascade)
  elements  DemolitionElement[]

  @@index([organizerId])
  @@index([status])
  @@index([postcode])
  @@index([createdAt])
}

model DemolitionElement {
  id                    String                  @id @default(cuid())
  projectId             String
  title                 String
  description           String?                 @db.Text
  isFree                Boolean                 @default(true)
  /// When chargeable: asking price in pence (payment arranged off-platform or future checkout).
  pricePence            Int?
  removalMustCompleteBy DateTime?
  pickupWhereWhen       String?                 @db.Text
  conditions            String?                 @db.Text
  quantityNote          String?
  sortOrder             Int                     @default(0)
  status                DemolitionElementStatus @default(available)
  claimedById           String?
  claimedAt             DateTime?
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt

  project   DemolitionProject             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  claimedBy User?                         @relation("DemolitionElementClaimedBy", fields: [claimedById], references: [id], onDelete: SetNull)
  interests DemolitionElementInterest[]

  @@index([projectId])
  @@index([status])
}

/// Registered interest for a chargeable demolition lot (organizer follows up).
model DemolitionElementInterest {
  id        String   @id @default(cuid())
  elementId String
  userId    String
  message   String?  @db.Text
  createdAt DateTime @default(now())

  element DemolitionElement @relation(fields: [elementId], references: [id], onDelete: Cascade)
  user    User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([elementId])
  @@index([userId])
  @@index([elementId, userId])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  type      String // wanted_ad_posted | offer_* | auction_outbid | auction_new_bid | auction_won | auction_ended_* …
  title     String
  body      String
  linkUrl   String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([userId, createdAt])
}

// ---- Orders (payments) ----
model Order {
  id                    String      @id @default(cuid())
  listingId             String
  buyerId               String
  sellerId              String
  amount                Int // total in pence (0 for free collection)
  platformFee           Int // in pence
  stripePaymentIntentId String?     @unique
  status                OrderStatus @default(pending)
  offerId               String?     @unique
  bidId                 String?     @unique
  /** Snapshot from listing at purchase (kg CO2e avoided vs new). */
  purchaseCarbonSavedKg       Float?
  /** Snapshot from listing at purchase (kg mass kept in use). */
  purchaseWasteDivertedKg     Float?
  quantity              Int         @default(1)
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  listing Listing @relation(fields: [listingId], references: [id])
  buyer   User    @relation("Buyer", fields: [buyerId], references: [id])
  seller  User    @relation("Seller", fields: [sellerId], references: [id])
  offer   Offer?  @relation(fields: [offerId], references: [id])
  bid     Bid?    @relation(fields: [bidId], references: [id])

  @@index([buyerId])
  @@index([sellerId])
  @@index([listingId])
  @@index([status])
}

// ---- Driven · Reclaimed (additive; ownerId/userId reference User.id without Prisma relation) ----

enum DrivenVehicleStatus {
  PRIVATE
  LISTED
  SOLD
}

enum DrivenTitleStatus {
  UNVERIFIED
  ESCROWED
  TRANSFERRED
}

enum DrivenSellerType {
  PRIVATE_PARTY
  DEALER
}

enum DrivenAuctionStatus {
  ACTIVE
  ENDED
  WITHDRAWN
}

enum DrivenGarageRelationship {
  OWNED
  WATCHING
  SOLD
}

enum DrivenValuationSource {
  HAGERTY
  MANUAL
  AUCTION_COMPARABLE
}

enum DrivenDocumentType {
  INVOICE
  PHOTO
  CERTIFICATE
  MOT
  BUILD_SHEET
  INSPECTION
  OTHER
}

enum DrivenEntryCategory {
  FACTORY
  OWNERSHIP
  SERVICE
  BODYWORK
  RESTORATION
  COMPETITION
  DOCUMENT
}

model DrivenVehicle {
  id                String              @id @default(cuid())
  reclaimedPublicId String              @unique // e.g. TRC-DRV-XXXXXXXX (public-facing)
  vin               String?
  registration      String
  make              String
  model             String
  year              Int
  colour            String?
  mileage           Int?
  imageUrls         String[]            @default([])
  ownerId           String
  passportScore     Int                 @default(0)
  status            DrivenVehicleStatus @default(PRIVATE)
  titleStatus    DrivenTitleStatus   @default(UNVERIFIED)
  sellerType     DrivenSellerType    @default(PRIVATE_PARTY)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  lineageEntries DrivenLineageEntry[]
  inspection     DrivenInspection?
  valuations     DrivenValuationSnapshot[]
  garageEntries  DrivenGarageEntry[]
  auction        DrivenAuctionListing?

  @@index([ownerId])
  @@index([registration])
  @@index([status])
}

model DrivenLineageEntry {
  id            String               @id @default(cuid())
  vehicleId     String
  vehicle       DrivenVehicle        @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  date          DateTime
  mileageAtTime Int?
  category      DrivenEntryCategory
  title         String
  description   String?
  cost          Int?
  workshop      String?
  documents     DrivenDocument[]
  createdAt     DateTime             @default(now())

  @@index([vehicleId])
  @@index([date])
}

model DrivenDocument {
  id         String             @id @default(cuid())
  entryId    String
  entry      DrivenLineageEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  type       DrivenDocumentType
  url        String
  fileName   String
  uploadedAt DateTime           @default(now())

  @@index([entryId])
}

model DrivenInspection {
  id            String        @id @default(cuid())
  vehicleId     String        @unique
  vehicle       DrivenVehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  overallScore  Int
  bodyAndPaint  Int
  mechanical    Int
  interior      Int
  underbody     Int
  electrics     Int
  reportUrl     String?
  inspectorName String?
  inspectedAt   DateTime
}

model DrivenValuationSnapshot {
  id             String                @id @default(cuid())
  vehicleId      String
  vehicle        DrivenVehicle         @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  capturedAt     DateTime              @default(now())
  estimatedValue Int
  source         DrivenValuationSource

  @@index([vehicleId])
  @@index([capturedAt])
}

model DrivenGarageEntry {
  id            String                   @id @default(cuid())
  userId        String
  vehicleId     String
  vehicle       DrivenVehicle            @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  relationship  DrivenGarageRelationship
  priceAlert    Int?
  notes         String?
  createdAt     DateTime                 @default(now())

  @@index([userId])
  @@index([vehicleId])
}

model DrivenAuctionListing {
  id                    String                 @id @default(cuid())
  vehicleId             String                 @unique
  vehicle               DrivenVehicle          @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  reservePrice          Int
  currentBid            Int                    @default(0)
  bidCount              Int                    @default(0)
  watcherCount          Int                    @default(0)
  endsAt                DateTime
  status                DrivenAuctionStatus    @default(ACTIVE)
  /// AI-generated neutral summary of the public Q&A thread (regenerated when comments change).
  qaAiOverview          String?                @db.Text
  qaAiOverviewUpdatedAt DateTime?
  createdAt             DateTime               @default(now())
  comments              DrivenAuctionComment[]

  @@index([status])
  @@index([endsAt])
}

/// Public threaded questions & comments on a Driven auction listing.
model DrivenAuctionComment {
  id               String                 @id @default(cuid())
  auctionListingId String
  auctionListing   DrivenAuctionListing   @relation(fields: [auctionListingId], references: [id], onDelete: Cascade)
  parentId         String?
  parent           DrivenAuctionComment?  @relation("DrivenAuctionCommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies          DrivenAuctionComment[] @relation("DrivenAuctionCommentReplies")
  userId           String
  user             User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  body             String                 @db.Text
  createdAt        DateTime               @default(now())

  @@index([auctionListingId, createdAt])
  @@index([parentId])
}
