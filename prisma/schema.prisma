// Reclaimed Marketplace - Prisma schema
// NextAuth v5 + Stripe Connect + Listings, Orders

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---- Enums ----
enum UserRole {
  individual
  reclamation_yard
}

enum ListingStatus {
  draft
  active
  sold
  ended // auction closed without sale (no bids or reserve not met)
  payment_pending // auction won; automatic charge failed or pending — winner must pay
}

enum OrderStatus {
  pending
  paid
  refunded
  disputed
}

enum Condition {
  like_new
  used
  worn
  parts_not_working
  refurbished
  upcycled
  collectable
}

enum ListingKind {
  sell
  auction
}

/// LOT = one price for the whole line; PER_UNIT = price × quantity (e.g. bricks).
enum ListingPricingMode {
  LOT
  PER_UNIT
}

enum OfferStatus {
  pending
  accepted
  declined
  withdrawn
}

enum ListingLocalYardAlertStatus {
  PENDING
  DECLINED
}

enum WantedAdStatus {
  active
  fulfilled
  closed
}

// ---- NextAuth (Auth.js v5) ----
model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  emailVerified DateTime?
  name          String?
  image         String?
  password      String?   // for credentials provider
  role          UserRole? // set when they become a seller
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  sellerProfile SellerProfile?
  ordersAsBuyer Order[]     @relation("Buyer")
  ordersAsSeller Order[]    @relation("Seller")
  listings      Listing[]
  offersMade    Offer[]     @relation("OffersMade")
  bids          Bid[]
  wantedAds     WantedAd[]
  notifications Notification[]
  listingFavorites ListingFavorite[]

  stripeCustomerId     String? @unique // platform Customer for saved auction payment method
  bidPaymentMethodId   String? // default PaymentMethod id (card on file for bids)
  localYardAlerts          ListingLocalYardAlert[] @relation("YardLocalAlerts")
  propRentalBookingsAsHirer PropRentalBooking[]    @relation("PropRentalHirer")
  propRentalBasketItems    PropRentalBasketItem[]  @relation("PropRentalBasketUser")
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}

// ---- Seller profile (1:1 when user sells) ----
model SellerProfile {
  id                String    @id @default(cuid())
  userId            String    @unique
  businessName      String?   // for reclamation_yard
  displayName       String
  postcode          String
  lat               Float?
  lng               Float?
  adminDistrict     String?   // town / borough (postcodes.io admin_district)
  region            String?   // e.g. England region / London
  openingHours         String?  // legacy free text (optional fallback)
  openingHoursSchedule Json?    // structured Mon–Sun for reclamation yards
  yardSlug             String?  @unique // public SEO URL for reclamation yards only
  yardTagline          String?   // short line for SEO / hero
  yardAbout            String?   @db.Text // longer about copy for page + meta
  yardLogoUrl          String?
  yardHeaderImageUrl   String?
  yardContactEmail     String?
  yardContactPhone     String?
  yardWebsiteUrl       String?
  yardSocialJson       Json?    // instagram, facebook, x, linkedin, tiktok URLs
  verificationStatus String?  @default("none") // none | pending | verified
  stripeAccountId   String?   // Stripe Connect account id when onboarding complete
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ---- Embodied carbon (ICE-style factors; admin-editable) ----
model CarbonFactor {
  id               String   @id @default(cuid())
  materialType     String // slug: timber, brick, steel, concrete, tile, other
  unitType         String // kg | m3 | tonne (factor is CO2e per this unit)
  co2PerUnit       Float // kg CO2e per unit
  source           String   @default("ICE Database")
  label            String // display name, e.g. "Timber (general)"
  densityKgPerM3   Float? // when converting m³ → kg for waste mass if unit is m3 row
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([materialType, unitType])
  @@index([materialType])
}

// ---- Categories ----
model Category {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  parentId  String?
  parent    Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryHierarchy")
  listings  Listing[]
  wantedAds WantedAd[]
}

// ---- Listings ----
model Listing {
  id                String        @id @default(cuid())
  sellerId          String
  title             String
  description       String
  price             Int // asking (sell) or starting bid (auction), pence; 0 when freeToCollector
  condition         Condition
  categoryId        String
  postcode          String?
  lat               Float?
  lng               Float?
  adminDistrict     String?
  region            String?
  images            String[] // blob URLs
  status            ListingStatus @default(draft)
  listingKind       ListingKind   @default(sell)
  pricingMode       ListingPricingMode @default(LOT)
  unitsAvailable    Int? // when PER_UNIT: units in stock; decremented on purchase until sold
  freeToCollector   Boolean       @default(false) // sell only: free pickup, no payment
  offersDelivery    Boolean       @default(false) // seller may arrange delivery (as well as collection)
  deliveryNotes     String? // extra context: packing, cut-offs, areas
  deliveryCostPence Int? // lowest fixed option in pence; null if all quote-only (legacy + summary)
  deliveryOptions   Json? // [{ carrier, customLabel?, pricePence | null }] preset carriers + prices
  auctionEndsAt        DateTime? // auction only: bidding closes at this time (UTC)
  auctionReservePence  Int? // optional minimum winning amount (pence); null = no reserve
  auctionFinalizedAt   DateTime? // set after end-of-auction settlement (reserve check / charge)
  boostedUntil         DateTime? // paid promotion window end timestamp
  boostLastPaymentIntentId String? // last processed Stripe PI for idempotency
  notifyLocalYards     Boolean   @default(false) // ping reclamation yards within radius when published (fixed-price sell)
  /// When false, listing is omitted from marketplace browse/search; yards may use for Prop Yard hire only.
  visibleOnMarketplace Boolean   @default(true)
  // Material / carbon (optional; ICE-based estimates when provided)
  materialType           String? // matches CarbonFactor.materialType
  materialQuantity       Float?
  materialUnit           String? // kg | tonne | m3
  distanceSavedKm        Float? // optional user note; not used in core formula yet
  carbonSavedKg          Float? // cached embodied carbon avoided (kg CO2e)
  carbonWasteDivertedKg  Float? // mass diverted (kg)
  carbonImpactJson       Json? // full breakdown for UI / API
  createdAt            DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  seller   User     @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id])
  orders   Order[]
  offers   Offer[]
  bids     Bid[]
  favorites ListingFavorite[]
  viewEvents ListingViewEvent[]
  localYardAlerts ListingLocalYardAlert[]
  propRentalOffer PropRentalOffer?

  @@index([sellerId])
  @@index([categoryId])
  @@index([status])
  @@index([lat, lng])
  @@index([createdAt])
  @@index([listingKind])
}

// ---- The Prop Yard (film / TV hire layer; reclamation yards only; links to existing listings) ----

enum PropRentalFulfillment {
  COLLECT_AND_RETURN
  YARD_DELIVERS_AND_COLLECTS
  ARRANGE_SEPARATELY
}

enum PropRentalBookingStatus {
  REQUESTED
  CONFIRMED
  OUT_ON_HIRE
  RETURNED
  CANCELLED
  DECLINED
}

/// One active prop-rental configuration per marketplace listing.
model PropRentalOffer {
  id               String   @id @default(cuid())
  listingId        String   @unique
  weeklyHirePence  Int // ex-VAT display; platform T&Cs apply
  minimumHireWeeks Int      @default(1)
  isActive         Boolean  @default(true)
  yardHireNotes    String?  @db.Text // collection, condition, deposit notes for hirers
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  listing         Listing                  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  bookings        PropRentalBooking[]
  unavailability  PropRentalUnavailability[]
  basketItems     PropRentalBasketItem[]

  @@index([isActive])
}

/// Yard-maintained blackout dates (maintenance, private hire, etc.).
model PropRentalUnavailability {
  id        String   @id @default(cuid())
  offerId   String
  startDate DateTime // inclusive, date-normalised UTC midnight
  endDate   DateTime // inclusive
  note      String?
  createdAt DateTime @default(now())

  offer PropRentalOffer @relation(fields: [offerId], references: [id], onDelete: Cascade)

  @@index([offerId])
  @@index([offerId, startDate])
}

model PropRentalBooking {
  id                       String                   @id @default(cuid())
  offerId                  String
  hirerId                  String
  hireStart                DateTime
  hireEnd                  DateTime
  billableWeeks            Int // ceil weeks between hireStart and hireEnd for quote
  totalHirePence           Int // billableWeeks * weekly at request time
  status                   PropRentalBookingStatus  @default(REQUESTED)
  fulfillment              PropRentalFulfillment
  contractAcceptedAt       DateTime?
  hirerOrgName             String?
  productionNotes          String?                  @db.Text
  deliveryArrangementNotes String?                  @db.Text
  createdAt                DateTime                 @default(now())
  updatedAt                DateTime                 @updatedAt

  offer PropRentalOffer @relation(fields: [offerId], references: [id], onDelete: Cascade)
  hirer User            @relation("PropRentalHirer", fields: [hirerId], references: [id], onDelete: Cascade)

  @@index([offerId])
  @@index([hirerId])
  @@index([status])
  @@index([hireStart, hireEnd])
}

model PropRentalBasketItem {
  id                       String              @id @default(cuid())
  userId                   String
  offerId                  String
  hireStart                DateTime
  hireEnd                  DateTime
  fulfillment              PropRentalFulfillment
  hirerOrgName             String?
  productionNotes          String?             @db.Text
  deliveryArrangementNotes String?             @db.Text
  createdAt                DateTime            @default(now())
  updatedAt                DateTime            @updatedAt

  user  User            @relation("PropRentalBasketUser", fields: [userId], references: [id], onDelete: Cascade)
  offer PropRentalOffer @relation(fields: [offerId], references: [id], onDelete: Cascade)

  @@unique([userId, offerId])
  @@index([userId])
  @@index([offerId])
}

model ListingFavorite {
  id        String   @id @default(cuid())
  userId    String
  listingId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
  @@index([listingId])
}

model ListingViewEvent {
  id        String   @id @default(cuid())
  listingId String
  createdAt DateTime @default(now())

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId, createdAt])
}

// Fixed-price listings: seller opted in to notify reclamation yards within ~50 mi
model ListingLocalYardAlert {
  id             String                      @id @default(cuid())
  listingId      String
  yardUserId     String
  status         ListingLocalYardAlertStatus @default(PENDING)
  distanceMiles  Float?
  linkedOfferId  String?                     @unique
  createdAt      DateTime                    @default(now())
  respondedAt    DateTime?

  listing     Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  yardUser    User    @relation("YardLocalAlerts", fields: [yardUserId], references: [id], onDelete: Cascade)
  linkedOffer Offer?  @relation(fields: [linkedOfferId], references: [id], onDelete: SetNull)

  @@unique([listingId, yardUserId])
  @@index([yardUserId])
  @@index([listingId])
}

model Bid {
  id          String   @id @default(cuid())
  listingId   String
  bidderId    String
  amountPence Int
  createdAt   DateTime @default(now())

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  bidder  User    @relation(fields: [bidderId], references: [id], onDelete: Cascade)
  order   Order?

  @@index([listingId])
  @@index([bidderId])
  @@index([listingId, amountPence])
}

model Offer {
  id            String      @id @default(cuid())
  listingId     String
  buyerId       String
  offeredPrice  Int // pence — agreed amount when accepted
  message       String?
  status        OfferStatus @default(pending)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  respondedAt   DateTime?

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  buyer   User    @relation("OffersMade", fields: [buyerId], references: [id], onDelete: Cascade)
  order   Order?
  localYardAlert ListingLocalYardAlert?

  @@index([listingId])
  @@index([buyerId])
  @@index([listingId, status])
}

model WantedAd {
  id             String         @id @default(cuid())
  userId         String
  title          String
  description    String
  categoryId     String?
  budgetMaxPence Int?
  postcode       String?
  lat            Float?
  lng            Float?
  adminDistrict  String?
  region         String?
  status         WantedAdStatus @default(active)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([categoryId])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  type      String // wanted_ad_posted | offer_received | offer_accepted | offer_declined | auction_outbid | auction_won
  title     String
  body      String
  linkUrl   String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([userId, createdAt])
}

// ---- Orders (payments) ----
model Order {
  id                    String      @id @default(cuid())
  listingId             String
  buyerId               String
  sellerId              String
  amount                Int // total in pence (0 for free collection)
  platformFee           Int // in pence
  stripePaymentIntentId String?     @unique
  status                OrderStatus @default(pending)
  offerId               String?     @unique
  bidId                 String?     @unique
  /** Snapshot from listing at purchase (kg CO2e avoided vs new). */
  purchaseCarbonSavedKg       Float?
  /** Snapshot from listing at purchase (kg mass kept in use). */
  purchaseWasteDivertedKg     Float?
  quantity              Int         @default(1)
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  listing Listing @relation(fields: [listingId], references: [id])
  buyer   User    @relation("Buyer", fields: [buyerId], references: [id])
  seller  User    @relation("Seller", fields: [sellerId], references: [id])
  offer   Offer?  @relation(fields: [offerId], references: [id])
  bid     Bid?    @relation(fields: [bidId], references: [id])

  @@index([buyerId])
  @@index([sellerId])
  @@index([listingId])
  @@index([status])
}

// ---- Driven · Reclaimed (additive; ownerId/userId reference User.id without Prisma relation) ----

enum DrivenVehicleStatus {
  PRIVATE
  LISTED
  SOLD
}

enum DrivenTitleStatus {
  UNVERIFIED
  ESCROWED
  TRANSFERRED
}

enum DrivenSellerType {
  PRIVATE_PARTY
  DEALER
}

enum DrivenAuctionStatus {
  ACTIVE
  ENDED
  WITHDRAWN
}

enum DrivenGarageRelationship {
  OWNED
  WATCHING
  SOLD
}

enum DrivenValuationSource {
  HAGERTY
  MANUAL
  AUCTION_COMPARABLE
}

enum DrivenDocumentType {
  INVOICE
  PHOTO
  CERTIFICATE
  MOT
  BUILD_SHEET
  INSPECTION
  OTHER
}

enum DrivenEntryCategory {
  FACTORY
  OWNERSHIP
  SERVICE
  BODYWORK
  RESTORATION
  COMPETITION
  DOCUMENT
}

model DrivenVehicle {
  id                String              @id @default(cuid())
  reclaimedPublicId String              @unique // e.g. TRC-DRV-XXXXXXXX (public-facing)
  vin               String?
  registration      String
  make              String
  model             String
  year              Int
  colour            String?
  mileage           Int?
  imageUrls         String[]            @default([])
  ownerId           String
  passportScore     Int                 @default(0)
  status            DrivenVehicleStatus @default(PRIVATE)
  titleStatus    DrivenTitleStatus   @default(UNVERIFIED)
  sellerType     DrivenSellerType    @default(PRIVATE_PARTY)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  lineageEntries DrivenLineageEntry[]
  inspection     DrivenInspection?
  valuations     DrivenValuationSnapshot[]
  garageEntries  DrivenGarageEntry[]
  auction        DrivenAuctionListing?

  @@index([ownerId])
  @@index([registration])
  @@index([status])
}

model DrivenLineageEntry {
  id            String               @id @default(cuid())
  vehicleId     String
  vehicle       DrivenVehicle        @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  date          DateTime
  mileageAtTime Int?
  category      DrivenEntryCategory
  title         String
  description   String?
  cost          Int?
  workshop      String?
  documents     DrivenDocument[]
  createdAt     DateTime             @default(now())

  @@index([vehicleId])
  @@index([date])
}

model DrivenDocument {
  id         String             @id @default(cuid())
  entryId    String
  entry      DrivenLineageEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  type       DrivenDocumentType
  url        String
  fileName   String
  uploadedAt DateTime           @default(now())

  @@index([entryId])
}

model DrivenInspection {
  id            String        @id @default(cuid())
  vehicleId     String        @unique
  vehicle       DrivenVehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  overallScore  Int
  bodyAndPaint  Int
  mechanical    Int
  interior      Int
  underbody     Int
  electrics     Int
  reportUrl     String?
  inspectorName String?
  inspectedAt   DateTime
}

model DrivenValuationSnapshot {
  id             String                @id @default(cuid())
  vehicleId      String
  vehicle        DrivenVehicle         @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  capturedAt     DateTime              @default(now())
  estimatedValue Int
  source         DrivenValuationSource

  @@index([vehicleId])
  @@index([capturedAt])
}

model DrivenGarageEntry {
  id            String                   @id @default(cuid())
  userId        String
  vehicleId     String
  vehicle       DrivenVehicle            @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  relationship  DrivenGarageRelationship
  priceAlert    Int?
  notes         String?
  createdAt     DateTime                 @default(now())

  @@index([userId])
  @@index([vehicleId])
}

model DrivenAuctionListing {
  id             String               @id @default(cuid())
  vehicleId      String               @unique
  vehicle        DrivenVehicle        @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  reservePrice   Int
  currentBid     Int                  @default(0)
  bidCount       Int                  @default(0)
  watcherCount   Int                  @default(0)
  endsAt         DateTime
  status         DrivenAuctionStatus  @default(ACTIVE)
  createdAt      DateTime             @default(now())

  @@index([status])
  @@index([endsAt])
}
