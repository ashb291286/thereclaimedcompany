// Reclaimed Marketplace - Prisma schema
// NextAuth v5 + Stripe Connect + Listings, Orders

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---- Enums ----
enum UserRole {
  individual
  reclamation_yard
}

enum ListingStatus {
  draft
  active
  sold
}

enum OrderStatus {
  pending
  paid
  refunded
  disputed
}

enum Condition {
  like_new
  used
  worn
  parts_not_working
  refurbished
  upcycled
  collectable
}

enum ListingKind {
  sell
  auction
}

enum OfferStatus {
  pending
  accepted
  declined
  withdrawn
}

enum WantedAdStatus {
  active
  fulfilled
  closed
}

// ---- NextAuth (Auth.js v5) ----
model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  emailVerified DateTime?
  name          String?
  image         String?
  password      String?   // for credentials provider
  role          UserRole? // set when they become a seller
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  sellerProfile SellerProfile?
  ordersAsBuyer Order[]     @relation("Buyer")
  ordersAsSeller Order[]    @relation("Seller")
  listings      Listing[]
  offersMade    Offer[]     @relation("OffersMade")
  bids          Bid[]
  wantedAds     WantedAd[]
  notifications Notification[]
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}

// ---- Seller profile (1:1 when user sells) ----
model SellerProfile {
  id                String    @id @default(cuid())
  userId            String    @unique
  businessName      String?   // for reclamation_yard
  displayName       String
  postcode          String
  lat               Float?
  lng               Float?
  adminDistrict     String?   // town / borough (postcodes.io admin_district)
  region            String?   // e.g. England region / London
  openingHours      String?   // free text or JSON string for yards
  verificationStatus String?  @default("none") // none | pending | verified
  stripeAccountId   String?   // Stripe Connect account id when onboarding complete
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ---- Categories ----
model Category {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  parentId  String?
  parent    Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryHierarchy")
  listings  Listing[]
  wantedAds WantedAd[]
}

// ---- Listings ----
model Listing {
  id                String        @id @default(cuid())
  sellerId          String
  title             String
  description       String
  price             Int // asking (sell) or starting bid (auction), pence; 0 when freeToCollector
  condition         Condition
  categoryId        String
  postcode          String?
  lat               Float?
  lng               Float?
  adminDistrict     String?
  region            String?
  images            String[] // blob URLs
  status            ListingStatus @default(draft)
  listingKind       ListingKind   @default(sell)
  freeToCollector   Boolean       @default(false) // sell only: free pickup, no payment
  offersDelivery    Boolean       @default(false) // seller may arrange delivery (as well as collection)
  deliveryNotes     String? // couriers, areas, lead times — shown to buyers
  deliveryCostPence Int? // null = quote on request; set = fixed UK delivery from £x
  auctionEndsAt     DateTime? // auction only: bidding closes at this time (UTC)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  seller   User     @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id])
  orders   Order[]
  offers   Offer[]
  bids     Bid[]

  @@index([sellerId])
  @@index([categoryId])
  @@index([status])
  @@index([lat, lng])
  @@index([createdAt])
  @@index([listingKind])
}

model Bid {
  id          String   @id @default(cuid())
  listingId   String
  bidderId    String
  amountPence Int
  createdAt   DateTime @default(now())

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  bidder  User    @relation(fields: [bidderId], references: [id], onDelete: Cascade)
  order   Order?

  @@index([listingId])
  @@index([bidderId])
  @@index([listingId, amountPence])
}

model Offer {
  id            String      @id @default(cuid())
  listingId     String
  buyerId       String
  offeredPrice  Int // pence — agreed amount when accepted
  message       String?
  status        OfferStatus @default(pending)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  respondedAt   DateTime?

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  buyer   User    @relation("OffersMade", fields: [buyerId], references: [id], onDelete: Cascade)
  order   Order?

  @@index([listingId])
  @@index([buyerId])
  @@index([listingId, status])
}

model WantedAd {
  id             String         @id @default(cuid())
  userId         String
  title          String
  description    String
  categoryId     String?
  budgetMaxPence Int?
  postcode       String?
  lat            Float?
  lng            Float?
  adminDistrict  String?
  region         String?
  status         WantedAdStatus @default(active)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([categoryId])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  type      String // wanted_ad_posted | offer_received | offer_accepted | offer_declined | auction_outbid | auction_won
  title     String
  body      String
  linkUrl   String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([userId, createdAt])
}

// ---- Orders (payments) ----
model Order {
  id                    String      @id @default(cuid())
  listingId             String
  buyerId               String
  sellerId              String
  amount                Int // total in pence (0 for free collection)
  platformFee           Int // in pence
  stripePaymentIntentId String?     @unique
  status                OrderStatus @default(pending)
  offerId               String?     @unique
  bidId                 String?     @unique
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  listing Listing @relation(fields: [listingId], references: [id])
  buyer   User    @relation("Buyer", fields: [buyerId], references: [id])
  seller  User    @relation("Seller", fields: [sellerId], references: [id])
  offer   Offer?  @relation(fields: [offerId], references: [id])
  bid     Bid?    @relation(fields: [bidId], references: [id])

  @@index([buyerId])
  @@index([sellerId])
  @@index([listingId])
  @@index([status])
}
